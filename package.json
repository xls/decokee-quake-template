{
  "name": "decokee-ai",
  "version": "0.0.61",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "start": "node scripts/dev.mjs",
    "build": "electron-vite build",
    "build:win": "npm run build && electron-builder --win --x64",
    "build:win32": "npm run build && electron-builder --win --ia32",
    "build:linux": "npm run build && electron-builder --linux",
    "build:linux-arm": "npm run build && electron-builder --linux --armv7l",
    "build:mac": "npm run build && electron-builder --mac",
    "rebuild": "electron-rebuild -f",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": {
    "name": "DECOKEE AI",
    "email": "decokee.ai@decokee.com",
    "url": "https://www.decokee.com"
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "@element-plus/icons-vue": "^2.3.2",
    "@imengyu/vue3-context-menu": "^1.5.4",
    "@mdi/svg": "^7.4.47",
    "active-win": "file:modules/active-win",
    "async-mutex": "^0.5.0",
    "axios": "^1.5.1",
    "clipboard": "^2.0.11",
    "decompress-zip": "^0.3.3",
    "electron-log": "^4.4.8",
    "electron-store": "^7.0.3",
    "element-plus": "^2.8.0",
    "express": "^4.18.2",
    "font-carrier": "file:modules/font-carrier",
    "howler": "2.1.3",
    "node-hid": "2.1.2",
    "robotjs": "file:modules/robotjs",
    "sharp": "^0.33.4",
    "shelljs": "^0.8.5",
    "uiohook-napi": "^1.5.4",
    "vue": "^3.4.0",
    "vue-i18n": "^9.14.0",
    "vuedraggable": "^4.1.0",
    "ws": "^8.15.1",
    "xmldom": "^0.6.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.3.0",
    "eslint": "^8.22.0",
    "eslint-plugin-vue": "^9.17.0",
    "less": "^4.2.0",
    "postcss": "^8.4.31",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.decokee.decokeeai",
    "productName": "DecoKeeAI",
    "copyright": "Copyright © 2024 DecoKee",
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "public/**/*"
    ],
    "win": {
      "icon": "public/app.png",
      "requestedExecutionLevel": "requireAdministrator",
      "target": [
        {
          "target": "nsis"
        }
      ]
    },
    "linux": {
      "icon": "public/app.png",
      "target": [
        "tar.gz"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}_Setup_${version}.${ext}"
    }
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "rules": {}
  },
  "eslintIgnore": [
    "iconfont.js"
  ]
}
